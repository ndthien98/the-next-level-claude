{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${FLEET_ROOT}/.claude/hooks/session-init.cjs",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "${FLEET_ROOT}/.claude/hooks/on-session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${FLEET_ROOT}/.claude/hooks/on-session-end.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${FLEET_ROOT}/.claude/hooks/on-pre-compact.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${FLEET_ROOT}/.claude/hooks/dev-rules-reminder.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${FLEET_ROOT}/.claude/hooks/check-file-ownership.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${FLEET_ROOT}/.claude/hooks/on-teammate-idle.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${FLEET_ROOT}/.claude/hooks/on-task-completed.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
