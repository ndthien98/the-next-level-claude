# The Next Level Claude — fleet config. Copy to .env and fill in real values.
# Or run `bash agents/onboard.sh` for an interactive setup that
# generates this file for you.

# ─── Telegram ────────────────────────────────────────────────────────
# Single bot for the whole fleet. Create one via @BotFather → /newbot.
# Token format: <numeric_id>:<alphanumeric_secret>
TG_BOT_TOKEN=

# Owner Telegram user id — master account with full bypass (high-trust).
# Find yours by messaging @userinfobot on Telegram. Numeric only.
TG_OWNER_ID=

# Chat where the bot listens for inbound.
#   1:1 DM with the bot: equals TG_OWNER_ID (positive integer).
#   Group / supergroup: negative integer (e.g. -1009876543210).
TG_ALLOWED_CHAT=

# Optional — bot username (no leading @). Used in autocomplete and error
# messages. Auto-detected via getMe if left blank.
BOT_USERNAME=

# ─── Owner identity ──────────────────────────────────────────────────
# Default attribution for artifacts (files, commits, docs) the fleet
# produces on your behalf. Written to `.state/identities.json` as the
# "default" entry; per-project overrides go in that file.
NEXT_LEVEL_OWNER_NAME=
NEXT_LEVEL_OWNER_EMAIL=

# ─── Fleet identity ──────────────────────────────────────────────────
# Display name (greetings, Agent Team name, slash-command labels).
FLEET_NAME=next-level-claude

# ─── Models per role ─────────────────────────────────────────────────
# Tier the model to the duty.
#   Opus    — heavy reasoning / orchestration / rigorous review
#   Sonnet  — bulk writing / fast iteration / mechanical work
#   Haiku   — cheap routing / classification / short tasks

CLAUDE_MODEL=claude-sonnet-4-6              # default fallback
CLAUDE_LEAD_MODEL=claude-opus-4-7           # project lead (orchestrator)

# Specialists picked by the lead based on task type
CLAUDE_MODEL_CODER=claude-sonnet-4-6
CLAUDE_MODEL_REVIEWER=claude-opus-4-7
CLAUDE_MODEL_DEBUGGER=claude-opus-4-7
CLAUDE_MODEL_PLANNER=claude-sonnet-4-6
CLAUDE_MODEL_BACKEND=claude-opus-4-7
CLAUDE_MODEL_FRONTEND=claude-sonnet-4-6
CLAUDE_MODEL_BLOCKCHAIN=claude-opus-4-7
CLAUDE_MODEL_DEVOPS=claude-sonnet-4-6
CLAUDE_MODEL_QA=claude-sonnet-4-6
CLAUDE_MODEL_SECURITY=claude-opus-4-7
CLAUDE_MODEL_RESEARCHER=claude-sonnet-4-6
CLAUDE_MODEL_DOCS=claude-haiku-4-5
CLAUDE_MODEL_ROUTER=claude-haiku-4-5

# ─── MCP servers ─────────────────────────────────────────────────────
# Comma-separated default MCP servers attached to every project.
# context7 is recommended for up-to-date library docs.
EXTRA_MCP=context7
